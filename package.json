{
  "name": "sprechi-v2",
  "version": "3.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "build/src/main.js",
  "scripts": {
    "build": "tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
    "dev": "CONSOLA_LEVEL=debug tsx src/dev.ts",
    "start": "node build/src/main.js",
    "preview": "node --env-file=.env.dev build/src/main.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/apply-migration.ts",
    "generate-tokens": "tsx src/scripts/generate-tokens.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:coverage:ui": "vitest --coverage --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@discordx/importer": "^1.3.3",
    "@napi-rs/canvas": "^0.1.97",
    "chart.js": "^4.5.1",
    "consola": "^3.4.2",
    "crypto-js": "^4.2.0",
    "csv-parse": "^6.2.1",
    "discord.js": "^14.25.1",
    "discordx": "^11.13.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "moment": "^2.30.1",
    "moment-duration-format": "^2.3.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "4.1.1",
    "chokidar": "^5.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.1",
    "vitest-mock-extended": "^3.1.0"
  },
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.12.0"
  },
  "packageManager": "pnpm@10.33.4+sha512.1c67b3b359b2d408119ba1ed289f34b8fc3c6873412bec6fd264fbdc82489e510fcbecb9ce9d22dae7f3b76269d8441046014bdca53b9979cd7a561ad631b800"
}
