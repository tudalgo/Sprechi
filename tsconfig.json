{
  "include": [
    "src/**/*",
    "tests/**/*"
  ],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "outDir": "build",
    "rootDir": ".",
    "strict": true,
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@db": [
        "./src/db"
      ],
      "@db/*": [
        "./src/db/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@managers/*": [
        "./src/managers/*"
      ],
      "@errors/*": [
        "./src/errors/*"
      ],
      "@commands/*": [
        "./src/commands/*"
      ],
      "@config/*": [
        "./src/config/*"
      ],
      "@events/*": [
        "./src/events/*"
      ],
      "@/*": [
        "./src/*"
      ],
    }
  },
  "exclude": [
    "build",
    "node_modules",
    "drizzle.config.ts",
    "eslint.config.ts",
  ]
}